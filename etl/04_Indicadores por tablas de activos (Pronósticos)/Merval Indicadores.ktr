    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>Proyectofb</connection>
    <sql>SELECT
  t1.simbolo AS simbolo,
  t1.cotizacion AS cotizacion ,
  t1.fecha AS fecha
FROM proyectofb.merval_historico t1
INNER JOIN (
    SELECT simbolo, MAX(fecha) AS fecha_max
    FROM proyectofb.merval_historico
    WHERE fecha &lt;= DATE_SUB(CURDATE(), INTERVAL 14 DAY)
    GROUP BY simbolo
) t2 ON t1.simbolo = t2.simbolo AND t1.fecha = t2.fecha_max;

</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
