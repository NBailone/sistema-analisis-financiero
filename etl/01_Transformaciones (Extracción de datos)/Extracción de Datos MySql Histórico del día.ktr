    <sql>SELECT
  simbolo
, cotizacion
, variacion
, apertura
, maximo
, minimo
, volumen
, ultimo_cierre
, cantidad_operaciones
, fecha
FROM proyectofb.bonos_historico where fecha BETWEEN DATE_SUB(CURDATE(),INTERVAL 4 DAY) AND curdate();</sql>
